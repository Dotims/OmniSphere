# OmniSphere — Local Environment Overrides
# Copy this file to .env.local (already gitignored) and fill in your values.
# This file SHOULD be committed as a template.

# IOTA RPC endpoint. Defaults to the public mainnet node defined in app.json.
# Override here if you run a private/dedicated node:
# EXPO_PUBLIC_IOTA_RPC_URL=https://your-private-node.example.com
